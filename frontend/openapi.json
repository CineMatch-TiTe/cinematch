{"openapi":"3.1.0","info":{"title":"cinematch-api","description":"","license":{"name":""},"version":"0.1.0"},"paths":{"/api/party":{"post":{"tags":["party"],"operationId":"create_party","responses":{"201":{"description":"Party created successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreatePartyResponse"}}}},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"User not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/join/{code}":{"post":{"tags":["party"],"operationId":"join_party","parameters":[{"name":"code","in":"path","description":"The 4-character party join code","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"Successfully joined party","content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreatePartyResponse"}}}},"400":{"description":"Invalid code or party not joinable","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/{party_id}":{"get":{"tags":["party"],"operationId":"get_party","parameters":[{"name":"party_id","in":"path","description":"The party's unique ID","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"Party details retrieved","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PartyResponse"}}}},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"Not a party member","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/{party_id}/advance":{"post":{"tags":["party"],"operationId":"advance_phase","parameters":[{"name":"party_id","in":"path","description":"The party ID","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"Phase advanced successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PhaseAdvanceResponse"}}}},"400":{"description":"Invalid state transition","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"Only party leader can advance phase","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/{party_id}/disband":{"post":{"tags":["party"],"summary":"Disband party","description":"Disbands the party completely. Only the party leader can disband.\nThis sets the party state to Disbanded and removes the join code.\n\n**Auth**: Only the party leader can disband the party.","operationId":"disband_party","parameters":[{"name":"party_id","in":"path","description":"The party ID","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"Party disbanded"},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"Only party leader can disband","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/{party_id}/kick":{"post":{"tags":["party"],"summary":"Kick a member from the party","description":"Removes a member from the party. Only the party leader can kick members.\nThe leader cannot kick themselves (use leave instead).\n\n**Auth**: Only the party leader can kick members.","operationId":"kick_member","parameters":[{"name":"party_id","in":"path","description":"The party ID","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/KickMemberRequest"}}},"required":true},"responses":{"200":{"description":"Member kicked successfully"},"400":{"description":"Cannot kick self or invalid request","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"Only party leader can kick members","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party or member not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/{party_id}/leave":{"post":{"tags":["party"],"summary":"Leave a party","description":"Removes the requesting user from the party.\nIf the leader leaves, leadership is transferred to the oldest member.\nIf no members remain, the party is disbanded.\n\n**Auth**: Requires authenticated user. Users can only leave for themselves.","operationId":"leave_party","parameters":[{"name":"party_id","in":"path","description":"The party ID to leave","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"Successfully left party"},"400":{"description":"Not a member of this party","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/{party_id}/members":{"get":{"tags":["party"],"operationId":"get_party_members","parameters":[{"name":"party_id","in":"path","description":"The party ID","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"Party members retrieved","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PartyMembersResponse"}}}},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"Not a party member","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/{party_id}/new-round":{"post":{"tags":["party"],"summary":"Start a new movie round","description":"Starts a new movie round from the Review state.\nOnly the party leader can start a new round.\nThis resets the party to Created state and generates a new join code.\nAll members' ready states are reset to false.\n\n**Auth**: Only the party leader can start a new round.","operationId":"start_new_round","parameters":[{"name":"party_id","in":"path","description":"The party ID","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"New round started","content":{"application/json":{"schema":{"$ref":"#/components/schemas/NewRoundResponse"}}}},"400":{"description":"Party is not in Review state","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"Only party leader can start new round","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/{party_id}/ready":{"post":{"tags":["party"],"operationId":"toggle_ready","parameters":[{"name":"party_id","in":"path","description":"The party ID","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SetReadyRequest"}}},"required":true},"responses":{"200":{"description":"Ready set"},"400":{"description":"Not a party member"},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party not found"},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/party/{party_id}/transfer-leadership":{"post":{"tags":["party"],"summary":"Transfer party leadership","description":"Transfers leadership to another party member.\nOnly the current leader can transfer leadership.\n\n**Auth**: Only the party leader can transfer leadership.","operationId":"transfer_leadership","parameters":[{"name":"party_id","in":"path","description":"The party ID","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/TransferLeadershipRequest"}}},"required":true},"responses":{"200":{"description":"Leadership transferred"},"400":{"description":"New leader is not a party member","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"Unauthorized","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"Only party leader can transfer leadership","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"Party not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/user":{"get":{"tags":["user"],"summary":"Get current user info","description":"Returns the currently authenticated user's profile information\nalong with JWT token validity details.\n\n**Auth Required**: User must be authenticated with a valid JWT token.","operationId":"get_current_user","responses":{"200":{"description":"User info retrieved successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/CurrentUserResponse"}}}},"401":{"description":"Unauthorized - authentication required","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"User not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearer_auth":[]}]}},"/api/user/login/guest":{"post":{"tags":["user"],"summary":"Create a guest user","description":"Creates a new temporary (oneshot) user with an auto-generated username.\nThis user can join parties but will be ephemeral to that party's lifetime.\nTo become persistent, the user must link an external OAuth account.\n\nThis is the entry point for users without an account. Use the returned `user_id`\nfor subsequent API requests that require authentication.\n\n**Auth**: No authentication required.","operationId":"login_guest","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GuestUserRequest"}}},"required":true},"responses":{"201":{"description":"Guest user created successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GuestLoginResponse"}}}},"400":{"description":"Invalid username","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"409":{"description":"Already logged in","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}}},"/api/user/logout":{"post":{"tags":["user"],"summary":"Logout user","description":"Clears authentication cookies by setting them to expire.\nThis effectively logs out the user on the client side.\n\n**Auth**: No authentication required (any user can logout).","operationId":"logout_user","responses":{"200":{"description":"Successfully logged out"},"204":{"description":"No user was logged in"},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}}},"/api/user/rename/{user_id}":{"patch":{"tags":["user"],"summary":"Rename a user","description":"Updates the username for a user. Username can be 3-32 characters.\n\n**Auth Required**: User can only rename their own account (user_id must match JWT token).\n\n","operationId":"rename_user","parameters":[{"name":"user_id","in":"path","description":"The user ID","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RenameUserRequest"}}},"required":true},"responses":{"200":{"description":"User renamed successfully"},"400":{"description":"Invalid username","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"Unauthorized - authentication required"},"403":{"description":"Forbidden - cannot rename another user"},"404":{"description":"User not found"},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}}},"/api/ws":{"get":{"tags":["websocket"],"operationId":"websocket_controller","responses":{"200":{"description":"WebSocket connection established"},"400":{"description":"WebSocket handshake failed: WebSocket upgrade is expected"},"401":{"description":"Unauthorized"},"406":{"description":"Not Acceptable - user is not in a party"},"500":{"description":"Internal server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}}}},"components":{"schemas":{"CreatePartyResponse":{"type":"object","description":"Response when creating a new party","required":["party_id","code","created_at"],"properties":{"code":{"type":"string","description":"The 4-character join code (e.g., \"A1B2\")"},"created_at":{"type":"string","format":"date-time","description":"When the party was created"},"party_id":{"type":"string","format":"uuid","description":"The unique party ID"}}},"CurrentUserResponse":{"type":"object","description":"Response with current user info and token details","required":["user_id","username","is_guest","created_at","updated_at","token_expires_at","token_expires_in"],"properties":{"created_at":{"type":"string","format":"date-time","description":"When the user was created"},"is_guest":{"type":"boolean","description":"Whether this is a guest/oneshot user"},"token_expires_at":{"type":"integer","format":"int64","description":"Token expiry timestamp (Unix seconds)"},"token_expires_in":{"type":"integer","format":"int64","description":"Seconds until token expiry"},"updated_at":{"type":"string","format":"date-time","description":"When the user was last updated"},"user_id":{"type":"string","format":"uuid","description":"The user's unique ID"},"username":{"type":"string","description":"The user's display name"}}},"ErrorResponse":{"type":"object","description":"Standard error response","required":["error"],"properties":{"error":{"type":"string"}}},"GuestLoginResponse":{"type":"object","description":"Response when creating a guest user","required":["user_id","username"],"properties":{"user_id":{"type":"string","format":"uuid","description":"The newly created user ID"},"username":{"type":"string","description":"The username"}}},"GuestUserRequest":{"type":"object","properties":{"username":{"type":["string","null"],"description":"Desired username for the guest user (optional)"}}},"KickMemberRequest":{"type":"object","description":"Request to kick a member (leader only)","required":["target_user_id"],"properties":{"target_user_id":{"type":"string","format":"uuid","description":"The user ID of the member to kick"}}},"MemberInfo":{"type":"object","description":"Information about a party member","required":["user_id","username","is_leader","is_ready","joined_at"],"properties":{"is_leader":{"type":"boolean","description":"Whether this member is the party leader"},"is_ready":{"type":"boolean","description":"Whether this member has marked themselves as ready"},"joined_at":{"type":"string","format":"date-time","description":"When the member joined the party"},"user_id":{"type":"string","format":"uuid","description":"The user's unique ID"},"username":{"type":"string","description":"The user's display name"}}},"NewRoundResponse":{"type":"object","description":"Response after starting a new round","required":["code"],"properties":{"code":{"type":"string","description":"New join code for the round"}}},"PartyMembersResponse":{"type":"object","description":"Response with list of party members","required":["members","count","ready_count","all_ready"],"properties":{"all_ready":{"type":"boolean","description":"Whether all members are ready"},"count":{"type":"integer","description":"Total count of members","minimum":0},"members":{"type":"array","items":{"$ref":"#/components/schemas/MemberInfo"},"description":"List of all members in the party"},"ready_count":{"type":"integer","description":"Number of members who are ready","minimum":0}}},"PartyResponse":{"type":"object","description":"Response with party details","required":["id","leader_id","state","created_at"],"properties":{"code":{"type":["string","null"],"description":"The join code (only present in Created state)"},"created_at":{"type":"string","format":"date-time","description":"When the party was created"},"id":{"type":"string","format":"uuid","description":"The unique party ID"},"leader_id":{"type":"string","format":"uuid","description":"The party leader's user ID"},"state":{"$ref":"#/components/schemas/PartyStateDto","description":"Current state of the party"}}},"PartyStateDto":{"type":"string","description":"Party state for API responses","enum":["created","picking","voting","watching","review","disbanded"]},"PhaseAdvanceResponse":{"type":"object","description":"Response after advancing to next phase","required":["new_state"],"properties":{"new_state":{"$ref":"#/components/schemas/PartyStateDto","description":"New party state after advancing"}}},"RenameUserRequest":{"type":"object","description":"Request to rename a user","required":["new_username"],"properties":{"new_username":{"type":"string","description":"The new username (max 32 characters)"}}},"SetReadyRequest":{"type":"object","description":"Request to set ready state","required":["is_ready"],"properties":{"is_ready":{"type":"boolean"}}},"TransferLeadershipRequest":{"type":"object","description":"Request to transfer leadership","required":["new_leader_id"],"properties":{"new_leader_id":{"type":"string","format":"uuid","description":"The user ID of the new leader"}}}}},"tags":[{"name":"user","description":"User management endpoints."},{"name":"party","description":"Party management endpoints."},{"name":"websocket","description":"WebSocket endpoints."}]}