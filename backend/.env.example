# Database environment configuration
# Copy this to .env and update values for your environment

# PostgreSQL Connection String
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://cinematch_user:cinematch_dev_password@localhost:5432/cinematch
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6334

# Logging
RUST_LOG=info
SECRET_TOKEN=reughughwriogjwpiogjwoipgjpewirgjopeiwughwoughfwiyufgwfuowgfowufhwofhgwoufhwuofgh
# TTL for JWTs (seconds, default 3600)
JWT_EXPIRY_SECS=3600

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8085

# Party phase timeouts (seconds). Background tick runs every 30s.
# VOTING_TIMEOUT_SECS: auto-end voting after this long (default 180).
# WATCHING_TIMEOUT_SECS: auto-advance Watching → Review after this long (default 900).
# VOTING_TIMEOUT_SECS=180
# WATCHING_TIMEOUT_SECS=900
